import {
    CheckBox,
    Button,
    VerticalBox,
    ScrollView,
    ListView,
    LineEdit,
} from "std-widgets.slint";

export struct TweakInfo {
    name: string,
    disabled: bool,
    icon: image,
}

export component MainWindow inherits Window {
    width: 560px;
    height: 440px;
    title: "Plugin Playground Configurator";

    in-out property <bool> use-legacy-ammonia;
    in-out property <bool> disable-pac;
    in-out property <bool> pause-injection;
    in property <[TweakInfo]> tweaks;
    in property <bool> dev-tools-available;
    in property <string> status-message;
    in-out property <image> default-icon: @image-url("drill.png");
    in property <string> daemon-status;
    in property <string> sip-status: "Unknown";

    callback save();
    callback edit-tweak(string);
    callback toggle-tweak(string);
    callback package-tweak(string);
    callback install-daemon();
    callback uninstall-daemon();

    VerticalBox {
        padding: 16px;
        spacing: 12px;

        Text {
            text: "Settings";
            font-weight: 700;
        }

        CheckBox {
            text: "Use legacy Ammonia tweaks folder";
            checked <=> root.use-legacy-ammonia;
        }

        CheckBox {
            text: "Disable arm64e (PAC) in newly spawned programs (Work In Progress)";
            checked <=> root.disable-pac;
        }

        CheckBox {
            text: "Pause tweak injection";
            checked <=> root.pause-injection;
        }

        Text {
            text: "System Status";
            font-weight: 700;
        }

        HorizontalLayout {
            spacing: 8px;
            Text {
                text: "SIP Status: " + root.sip-status;
                color: root.sip-status == "Enabled" ? #e74c3c : (root.sip-status == "Partially Disabled (Debugging Restrictions Off)" ? #2ecc71 : #e67e22);
                vertical-alignment: center;
            }
            Text {
                text: root.sip-status == "Enabled" ? "(Plugin Playground requires SIP to be disabled or partially disabled)" : "";
                color: #e74c3c;
                font-size: 11px;
                vertical-alignment: center;
            }
        }

        Text {
            text: "Launch Daemon";
            font-weight: 700;
        }

        HorizontalLayout {
            spacing: 8px;
            Text {
                text: root.daemon-status;
                color: #888;
                vertical-alignment: center;
            }

            HorizontalLayout {
                horizontal-stretch: 1;
            }

            Button {
                text: "Install";
                visible: root.daemon-status == "Not Installed";
                clicked => { root.install-daemon(); }
            }

            Button {
                text: "Uninstall";
                visible: root.daemon-status != "Not Installed";
                clicked => { root.uninstall-daemon(); }
            }
        }

        Text {
            text: "Installed Tweaks";
            font-weight: 700;
        }

        ScrollView {
            vertical-stretch: 1;
            ListView {
                for tweak in root.tweaks: HorizontalLayout {
                    spacing: 8px;
                    padding: 8px;
                    Image {
                        source: tweak.icon;
                        width: 24px;
                        height: 24px;
                    }

                    VerticalLayout {
                        spacing: 2px;
                        Text {
                            text: tweak.name;
                            font-size: 14px;
                            font-weight: 600;
                        }

                        HorizontalLayout {
                            spacing: 4px;
                            Rectangle {
                                width: 8px;
                                height: 8px;
                                border-radius: 4px;
                                background: tweak.disabled ? #e74c3c : #2ecc71;
                            }

                            Text {
                                text: tweak.disabled ? "Disabled" : "Enabled";
                                font-size: 11px;
                                color: tweak.disabled ? #e74c3c : #2ecc71;
                            }
                        }
                    }

                    HorizontalLayout {
                        horizontal-stretch: 1;
                    }

                    HorizontalLayout {
                        spacing: 4px;
                        Button {
                            text: "Edit";
                            horizontal-stretch: 1;
                            min-width: 72px;
                            clicked => {
                                root.edit-tweak(tweak.name);
                            }
                        }

                        Button {
                            text: tweak.disabled ? "Enable" : "Disable";
                            horizontal-stretch: 1;
                            min-width: 72px;
                            clicked => {
                                root.toggle-tweak(tweak.name);
                            }
                        }

                        Button {
                            text: "Package";
                            visible: root.dev-tools-available;
                            horizontal-stretch: 1;
                            min-width: 72px;
                            clicked => {
                                root.package-tweak(tweak.name);
                            }
                        }
                    }
                }
            }
        }

        HorizontalLayout {
            spacing: 8px;
            Button {
                text: "Save Settings";
                min-width: 120px;
                clicked => {
                    root.save();
                }
            }

            HorizontalLayout {
                horizontal-stretch: 1;
            }
        }

        Text {
            text: root.status-message;
            color: #888;
            font-size: 12px;
            visible: root.status-message != "";
        }
    }
}

export component TweakEditor inherits Window {
    width: 500px;
    height: 440px;
    title: "Tweak Options";

    in property <string> tweak-name;
    in-out property <[string]> blacklisted-apps;
    in-out property <[string]> framework-deps;

    callback add-blacklisted(string);
    callback add-framework-dep(string);
    callback remove-blacklisted(string);
    callback remove-framework-dep(string);
    callback save();
    callback cancel();

    VerticalBox {
        padding: 16px;
        spacing: 8px;

        Text {
            text: root.tweak-name + " Options";
            font-weight: 700;
            font-size: 16px;
        }

        Text {
            text: "Blacklisted Applications";
            font-weight: 600;
        }

        ScrollView {
            vertical-stretch: 1;
            ListView {
                for app in root.blacklisted-apps: HorizontalLayout {
                    spacing: 8px;
                    padding-top: 4px;
                    padding-bottom: 4px;
                    Text {
                        text: app;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                    }

                    Button {
                        text: "-";
                        min-width: 28px;
                        clicked => {
                            root.remove-blacklisted(app);
                        }
                    }
                }
            }
        }

        HorizontalLayout {
            spacing: 8px;
            i-bl-input := LineEdit {
                placeholder-text: "Executable Name";
                horizontal-stretch: 1;
                accepted => {
                    root.add-blacklisted(self.text);
                    self.text = "";
                }
            }

            Button {
                text: "+ Add";
                min-width: 60px;
                clicked => {
                    root.add-blacklisted(i-bl-input.text);
                    i-bl-input.text = "";
                }
            }
        }

        Text {
            text: "Framework Dependencies";
            font-weight: 600;
        }

        ScrollView {
            vertical-stretch: 1;
            ListView {
                for dep in root.framework-deps: HorizontalLayout {
                    spacing: 8px;
                    padding-top: 4px;
                    padding-bottom: 4px;
                    Text {
                        text: dep;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                    }

                    Button {
                        text: "-";
                        min-width: 28px;
                        clicked => {
                            root.remove-framework-dep(dep);
                        }
                    }
                }
            }
        }

        HorizontalLayout {
            spacing: 8px;
            i-fw-input := LineEdit {
                placeholder-text: "Framework name...";
                horizontal-stretch: 1;
                accepted => {
                    root.add-framework-dep(self.text);
                    self.text = "";
                }
            }

            Button {
                text: "+ Add";
                min-width: 60px;
                clicked => {
                    root.add-framework-dep(i-fw-input.text);
                    i-fw-input.text = "";
                }
            }
        }

        HorizontalLayout {
            spacing: 8px;
            HorizontalLayout {
                horizontal-stretch: 1;
            }

            Button {
                text: "Save";
                min-width: 80px;
                clicked => {
                    root.save();
                }
            }

            Button {
                text: "Cancel";
                min-width: 80px;
                clicked => {
                    root.cancel();
                }
            }
        }
    }
}
